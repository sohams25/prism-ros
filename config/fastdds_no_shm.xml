<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Fast-DDS profile that disables the shared-memory transport and uses UDPv4
  only. Avoids the RTPS_TRANSPORT_SHM "Failed init_port" errors caused by
  stale /dev/shm/fastrtps_* lock files left behind by crashed processes.
  UDP loopback on localhost is fine for this project — we're already using
  intra-process comms (unique_ptr move) for the hot path.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_only</transport_id>
      <type>UDPv4</type>
    </transport_descriptor>
  </transport_descriptors>

  <participant profile_name="udp_only_participant" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_only</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>
</profiles>
